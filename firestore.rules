rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if user is teacher
    function isTeacher() {
      return isAuth() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'teacher';
    }

    // Helper function to check if user is owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ===== STUDENTS =====
    match /students/{studentId} {
      // Anyone authenticated can read (for teacher to manage students)
      allow read: if isAuth();

      // Create: anyone can create (for registration)
      allow create: if true;

      // Update: owner can update own profile, teacher can update anyone
      allow update: if isOwner(studentId) || isTeacher();

      // Delete: only teacher can delete
      allow delete: if isTeacher();
    }

    // ===== GROUPS =====
    match /groups/{groupId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== SECTIONS =====
    match /sections/{sectionId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== VIDEOS =====
    match /videos/{videoId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== PATENTE TRICKS =====
    match /patenteTricks/{trickId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== PATENTE QUIZZES =====
    match /patenteQuizzes/{quizId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== PATENTE QUIZZES TEST =====
    match /patenteQuizzesTest/{quizId} {
      // Authenticated users can read
      allow read: if isAuth();

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== COURSE CARDS =====
    match /courseCards/{cardId} {
      // Anyone can read (for landing page)
      allow read: if true;

      // Only teacher can create/update/delete
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // ===== QUIZ HISTORY =====
    match /quizHistory/{historyId} {
      // Owner can read own history, teacher can read all
      allow read: if isOwner(resource.data.studentId) || isTeacher();

      // Authenticated users can create (save their own history)
      allow create: if isAuth() && request.resource.data.studentId == request.auth.uid;

      // Only teacher can update/delete
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }
  }
}
